    "react-test-renderer": "19.1.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-geolocation-service",
          "react-native-sensors",
          "react-native-version-check",
          "@react-native-community/masked-view",
