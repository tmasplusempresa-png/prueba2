{
  "name": "tmasplus",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e": "maestro test .maestro/",
    "test:e2e:login": "maestro test .maestro/login.yaml",
    "test:e2e:record": "maestro record .maestro/full_flow.yaml",
    "lint": "expo lint",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "dev": "APP_VARIANT=development npx expo start",
    "update-version": "node scripts/updateVersion.js",
    "auto:sub:android": "eas build --platform android --auto-submit",
    "auto:sub:ios": "eas build --platform ios --auto-submit",
    "developer": "eas build --platform ios --profile development",
    "app:publish": "eas update --branch preview",
    "preview": "node scripts/updateAppIdentifier.js --channel=preview && eas build --profile preview",
    "production": "node scripts/updateAppIdentifier.js --channel=production && eas build --profile production",
    "build": "npm run update-version && eas build",
    "expo:upgrade:54": "npx expo upgrade 54.0.0"
  },
  "dependencies": {
    "@babel/plugin-transform-template-literals": "^7.24.7",
    "@expo/vector-icons": "^15.0.3",
    "@google-cloud/vision": "^4.3.0",
